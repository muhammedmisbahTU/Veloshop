<div class="min-h-screen bg-black text-white p-6">
    <div class="max-w-7xl mx-auto">
                            SEC
        <div class="grid lg:grid-cols-2 gap-8">
                            PVT
            <!-- LEFT SIDE -->
            <div
                class="hidden lg:flex flex-col justify-between rounded-3xl  overflow-hidden">
                            OK
                <!-- Logo -->
                <div class="p-8">
                    <h1 class="text-3xl font-bold tracking-wide">
                        <span class="text-lime-400">V</span> VELOSHOP
                    </h1>
                </div>

                <!-- Product Image -->
                <div class="flex justify-center px-8">
                    <img
                        src="/images/auth/headphone.png"
                        alt="Headphone"
                        class="max-h-[500px] object-contain">
                </div>

                <!-- Bottom Features -->
                <div class="grid grid-cols-3 ">

                    <div class="p-5 text-center">
                        <div
                            class="w-12 h-12 mx-auto mb-3 rounded-full bg-lime-500/10 flex items-center justify-center text-lime-400">
                            
                        </div>

                        <h3 class="font-medium">
                            Secure & Encrypted
                        </h3>

                        <p class="text-xs text-gray-400 mt-2">
                            Your data is protected.
                        </p>
                    </div>

                    <div class="p-5 text-center ">
                        <div
                            class="w-12 h-12 mx-auto mb-3 rounded-full bg-lime-500/10 flex items-center justify-center text-lime-400">
                            
                        </div>

                        <h3 class="font-medium">
                            Private & Trusted
                        </h3>

                        <p class="text-xs text-gray-400 mt-2">
                            We never share information.
                        </p>
                    </div>

                    <div class="p-5 text-center">
                        <div
                            class="w-12 h-12 mx-auto mb-3 rounded-full bg-lime-500/10 flex items-center justify-center text-lime-400">
                            
                        </div>

                        <h3 class="font-medium">
                            Protected Always
                        </h3>

                        <p class="text-xs text-gray-400 mt-2">
                            Industry-grade security.
                        </p>
                    </div>

                </div>
            </div>

            <!-- RIGHT SIDE -->
            <div class="flex items-center justify-center">

                <div
                    class="w-full max-w-2xl rounded-3xl border border-lime-500/20 bg-zinc-950 p-8 shadow-2xl">

                    <!-- Logo -->
                    <div class="text-center mb-8">
                        <h2 class="text-3xl font-bold">
                            Verify your
                            <span class="text-lime-400">account</span>
                        </h2>

                        <p class="text-gray-400 mt-3">
                            Enter the 6-digit verification code sent to
                        </p>

                        <p class="mt-2 text-lime-400 font-medium">
                            <%= email %>
                        </p>
                    </div>

                    <!-- Flash messages / AJAX containers -->
                    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                        <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl p-4 text-sm mb-5 text-center">
                            <%= errorMessage %>
                        </div>
                    <% } %>
                    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
                        <div class="bg-lime-500/10 border border-lime-500/30 text-lime-400 rounded-xl p-4 text-sm mb-5 text-center">
                            <%= successMessage %>
                        </div>
                    <% } %>
                    <div id="alert-container" class="hidden rounded-xl p-4 text-sm mb-5 text-center"></div>

                    <!-- OTP Inputs -->
                    <form
                        id="verifyForm"
                        action="/verify-otp"
                        method="POST">

                        <input
                            type="hidden"
                            name="email"
                            value="<%= email %>">

                        <div
                            class="flex justify-center gap-3 mb-8">

                            <% for(let i=0;i<6;i++){ %>
                                <input
                                    type="text"
                                    maxlength="1"
                                    class="otp-input w-14 h-16 text-center text-2xl rounded-xl bg-black border border-zinc-700 focus:border-lime-400 focus:outline-none">
                            <% } %>

                        </div>

                        <input
                            type="hidden"
                            id="otp"
                            name="otp">

                        <!-- Timer -->
                        <div
                            class="text-center text-sm text-gray-400 mb-6">
                            Code expires in
                            <span
                                id="timer"
                                class="text-lime-400 font-semibold">
                                05:00
                            </span>
                        </div>

                        <!-- Info Box -->
                        <div
                            class="rounded-xl border border-zinc-800 p-4 bg-zinc-900 mb-6">

                            <p class="text-sm text-gray-300">
                                Enter the verification code sent to your
                                email address.
                            </p>

                        </div>

                        <!-- Submit -->
                        <button
                            type="submit"
                            class="w-full bg-lime-400 text-black py-4 rounded-xl font-bold text-lg hover:bg-lime-300 transition">

                            Verify OTP
                        </button>

                    </form>

                    <!-- Resend -->
                    <div
                        class="mt-6 flex justify-between items-center">

                        <form
                            id="resendForm"
                            action="/resend-otp"
                            method="POST">

                            <input
                                type="hidden"
                                name="email"
                                value="<%= email %>">

                            <button
                                id="resendBtn"
                                type="submit"
                                class="text-gray-300 hover:text-lime-400">

                                Resend OTP
                            </button>

                        </form>

                        <span
                            class="text-sm text-gray-500">
                            Attempts Remaining:
                            <span id="attemptsCount" class="text-lime-400">
                                <%= attemptsLeft %>
                            </span>
                        </span>
                    </div>

                    <!-- Back -->
                    <div class="mt-8 text-center">
                        <a
                            href="/register"
                            class="text-gray-400 hover:text-lime-400">

                            Back to Register

                        </a>
                    </div>

                </div>

            </div>

        </div>

    </div>
</div>

<script>
    const inputs = document.querySelectorAll(".otp-input");
    const otpField = document.getElementById("otp");
    const verifyForm = document.getElementById("verifyForm");
    const resendForm = document.getElementById("resendForm");
    const alertContainer = document.getElementById("alert-container");
    const attemptsCount = document.getElementById("attemptsCount");
    const timer = document.getElementById("timer");
    const submitBtn = verifyForm.querySelector("button[type='submit']");

    inputs.forEach((input, index) => {
        input.addEventListener("input", () => {
            if (input.value && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
            otpField.value = [...inputs].map(i => i.value).join("");
        });

        input.addEventListener("keydown", (e) => {
            if (e.key === "Backspace" && !input.value && index > 0) {
                inputs[index - 1].focus();
            }
        });
    });

    let time = 300;
    let interval;

    function startTimer() {
        clearInterval(interval);
        time = 300;
        submitBtn.removeAttribute("disabled");
        submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
        
        interval = setInterval(() => {
            let min = String(Math.floor(time / 60)).padStart(2, "0");
            let sec = String(time % 60).padStart(2, "0");
            timer.textContent = `${min}:${sec}`;
            time--;

            if (time < 0) {
                clearInterval(interval);
                timer.textContent = "Expired";
                submitBtn.setAttribute("disabled", "true");
                submitBtn.classList.add("opacity-50", "cursor-not-allowed");
            }
        }, 1000);
    }

    startTimer();

    // Verify OTP AJAX Submission
    verifyForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        alertContainer.classList.add("hidden");
        alertContainer.className = "rounded-xl p-4 text-sm mb-5 text-center";
        
        const email = verifyForm.querySelector("input[name='email']").value;
        const otp = otpField.value;

        if (otp.length !== 6) {
            alertContainer.classList.remove("hidden");
            alertContainer.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
            alertContainer.textContent = "Please enter all 6 digits of the OTP.";
            return;
        }

        try {
            const response = await fetch("/verify-otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, otp })
            });

            const result = await response.json();

            if (response.ok && result.success) {
                alertContainer.classList.remove("hidden");
                alertContainer.classList.add("bg-lime-500/10", "border", "border-lime-500/30", "text-lime-400");
                alertContainer.textContent = result.message || "Email verified! Redirecting...";
                setTimeout(() => {
                    if (result.role === "ADMIN") {
                        window.location.href = "/admin/users";
                    } else {
                        window.location.href = "/";
                    }
                }, 1500);
            } else {
                alertContainer.classList.remove("hidden");
                alertContainer.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
                alertContainer.textContent = result.message || "Invalid verification code.";
                if (result.attemptsLeft !== undefined) {
                    attemptsCount.textContent = result.attemptsLeft;
                }
            }
        } catch (err) {
            alertContainer.classList.remove("hidden");
            alertContainer.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
            alertContainer.textContent = "A network error occurred. Please try again.";
        }
    });

    // Resend OTP AJAX Submission
    resendForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        alertContainer.classList.add("hidden");
        alertContainer.className = "rounded-xl p-4 text-sm mb-5 text-center";
        
        const email = resendForm.querySelector("input[name='email']").value;

        try {
            const response = await fetch("/resend-otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email })
            });

            const result = await response.json();

            if (response.ok && result.success) {
                alertContainer.classList.remove("hidden");
                alertContainer.classList.add("bg-lime-500/10", "border", "border-lime-500/30", "text-lime-400");
                alertContainer.textContent = result.message || "OTP resent successfully!";
                
                // Clear input boxes
                inputs.forEach(i => i.value = "");
                otpField.value = "";
                
                // Restart timer
                startTimer();
                
                // Reset attempts displays
                attemptsCount.textContent = "5";
            } else {
                alertContainer.classList.remove("hidden");
                alertContainer.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
                alertContainer.textContent = result.message || "Failed to resend OTP.";
            }
        } catch (err) {
            alertContainer.classList.remove("hidden");
            alertContainer.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
            alertContainer.textContent = "A network error occurred. Please try again.";
        }
    });
</script>
