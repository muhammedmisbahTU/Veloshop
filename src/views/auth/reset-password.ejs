<div class="min-h-screen bg-black text-white p-6 flex items-center justify-center">
    <div class="w-full max-w-xl bg-zinc-950 border border-lime-500/20 rounded-3xl p-8 backdrop-blur-xl shadow-2xl">

        <!-- Logo -->
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold">
                Reset
                <span class="text-lime-400">Password</span>
            </h2>
            <p class="text-gray-400 mt-3">
                Enter the verification code sent to your email and choose a secure new password.
            </p>
        </div>

        <div id="alert-container" class="hidden rounded-xl p-4 text-sm mb-5 text-center"></div>

        <!-- Form -->
        <form id="resetForm" class="space-y-5">

            <!-- Email (Hidden or Read-only) -->
            <div>
                <label class="block text-sm text-gray-300 mb-2">
                    Email address
                </label>
                <input
                    type="email"
                    name="email"
                    value="<%= email %>"
                    class="w-full bg-black/40 border border-zinc-800 rounded-xl px-4 py-3 text-gray-500 focus:outline-none"
                    readonly
                >
            </div>

            <!-- OTP Code -->
            <div>
                <label class="block text-sm text-gray-300 mb-2">
                    6-Digit Verification Code
                </label>
                <input
                    type="text"
                    name="otp"
                    maxlength="6"
                    placeholder="Enter 6-digit OTP"
                    class="w-full bg-black border border-zinc-700 rounded-xl px-4 py-3 focus:border-lime-400 focus:outline-none text-white text-center tracking-widest font-bold text-lg"
                    required
                >
            </div>

            <!-- New Password -->
            <div>
                <label class="block text-sm text-gray-300 mb-2">
                    New Password
                </label>
                <input
                    type="password"
                    name="password"
                    placeholder="Min 6 characters"
                    class="w-full bg-black border border-zinc-700 rounded-xl px-4 py-3 focus:border-lime-400 focus:outline-none text-white"
                    required
                >
            </div>

            <!-- Confirm Password -->
            <div>
                <label class="block text-sm text-gray-300 mb-2">
                    Confirm New Password
                </label>
                <input
                    type="password"
                    name="confirmPassword"
                    placeholder="Verify new password"
                    class="w-full bg-black border border-zinc-700 rounded-xl px-4 py-3 focus:border-lime-400 focus:outline-none text-white"
                    required
                >
            </div>

            <!-- Submit -->
            <button
                type="submit"
                class="w-full h-14 bg-lime-400 hover:bg-lime-300 text-black font-bold rounded-xl transition-all duration-300 flex items-center justify-center gap-2"
            >
                Reset Password
            </button>

        </form>

        <!-- Back to Login -->
        <div class="mt-8 text-center">
            <a
                href="/login"
                class="text-gray-400 hover:text-lime-400 transition"
            >
                Cancel and Back to Login
            </a>
        </div>

    </div>
</div>

<script>
const form = document.getElementById('resetForm');
const alertContainer = document.getElementById('alert-container');
const submitBtn = form.querySelector("button[type='submit']");

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  alertContainer.classList.add('hidden');
  alertContainer.className = 'rounded-xl p-4 text-sm mb-5 text-center';
  
  const formData = new FormData(form);
  const data = Object.fromEntries(formData.entries());

  if (data.otp.length !== 6) {
    alertContainer.classList.remove('hidden');
    alertContainer.classList.add('bg-red-500/10', 'border', 'border-red-500/30', 'text-red-400');
    alertContainer.textContent = 'Please enter a valid 6-digit OTP code.';
    return;
  }

  if (data.password !== data.confirmPassword) {
    alertContainer.classList.remove('hidden');
    alertContainer.classList.add('bg-red-500/10', 'border', 'border-red-500/30', 'text-red-400');
    alertContainer.textContent = 'Passwords do not match.';
    return;
  }

  submitBtn.setAttribute("disabled", "true");
  submitBtn.textContent = "Updating...";

  try {
    const response = await fetch('/reset-password', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });

    const result = await response.json();

    if (response.ok && result.success) {
      alertContainer.classList.remove('hidden');
      alertContainer.classList.add('bg-lime-500/10', 'border', 'border-lime-500/30', 'text-lime-400');
      alertContainer.textContent = result.message || 'Password updated successfully! Redirecting...';
      
      setTimeout(() => {
        window.location.href = '/login';
      }, 2000);
    } else {
      submitBtn.removeAttribute("disabled");
      submitBtn.textContent = "Reset Password";
      alertContainer.classList.remove('hidden');
      alertContainer.classList.add('bg-red-500/10', 'border', 'border-red-500/30', 'text-red-400');
      alertContainer.textContent = result.message || 'Failed to reset password.';
    }
  } catch (error) {
    submitBtn.removeAttribute("disabled");
    submitBtn.textContent = "Reset Password";
    alertContainer.classList.remove('hidden');
    alertContainer.classList.add('bg-red-500/10', 'border', 'border-red-500/30', 'text-red-400');
    alertContainer.textContent = 'A network error occurred. Please try again.';
  }
});
</script>
