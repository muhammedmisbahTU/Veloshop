

<div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen bg-black text-white">

    <!-- LEFT SIDE (Branding / Visual) -->
    <div class="hidden lg:flex flex-col justify-center p-16 relative bg-[url('/images/login-gaming-bg.jpg')] bg-cover bg-center">

        <div class="absolute inset-0 bg-black/80"></div>

        <div class="relative z-10">

            <h1 class="text-5xl font-extrabold leading-tight">
                GEAR UP.<br>
                CREATE <span class="text-lime-400">LEGENDS.</span>
            </h1>

            <p class="mt-6 text-gray-300 max-w-md">
                Join Veloshop and experience premium gaming gear built for champions.
            </p>

            <div class="mt-10 space-y-6">

                <div class="flex items-start gap-3">
                    <span class="text-lime-400 text-sm font-bold">SEC</span>
                    <div>
                        <h4 class="font-semibold">Secure & Private</h4>
                        <p class="text-sm text-gray-400">Your data is encrypted end-to-end.</p>
                    </div>
                </div>

                <div class="flex items-start gap-3">
                    <span class="text-lime-400 text-sm font-bold">FAST</span>
                    <div>
                        <h4 class="font-semibold">Fast & Reliable</h4>
                        <p class="text-sm text-gray-400">Lightning-fast delivery worldwide.</p>
                    </div>
                </div>

                <div class="flex items-start gap-3">
                    <span class="text-lime-400 text-sm font-bold">TRUST</span>
                    <div>
                        <h4 class="font-semibold">Trusted by Gamers</h4>
                        <p class="text-sm text-gray-400">500K+ active users globally.</p>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <!-- RIGHT SIDE (FORM) -->
    <div class="flex items-center justify-center p-6">

        <div class="w-full max-w-xl bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-xl">

            <!-- Top -->
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-bold">Create your account</h2>
                <a href="/login" class="text-lime-400 text-sm hover:underline">
                    Login
                </a>
            </div>

            <p class="text-gray-400 text-sm mb-8">
                Join Veloshop and elevate your gaming experience.
            </p>

            <!-- Flash messages -->
            <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl p-4 text-sm mb-5">
                    <%= errorMessage %>
                </div>
            <% } %>
            <% if (typeof successMessage !== 'undefined' && successMessage) { %>
                <div class="bg-lime-500/10 border border-lime-500/30 text-lime-400 rounded-xl p-4 text-sm mb-5">
                    <%= successMessage %>
                </div>
            <% } %>
            <div id="error-container" class="hidden bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl p-4 text-sm mb-5"></div>

            <!-- FORM -->
            <form action="/register" method="POST" class="space-y-4">

                <!-- Name + Email -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                    <div>
                        <label class="text-sm text-gray-300">Full Name</label>
                        <input type="text" name="fullName"
                            class="w-full mt-2 p-3 bg-black/60 border border-white/10 rounded-xl focus:border-lime-400 outline-none"
                            placeholder="Enter your name">
                    </div>

                    <div>
                        <label class="text-sm text-gray-300">Email Address</label>
                        <input type="email" name="email"
                            class="w-full mt-2 p-3 bg-black/60 border border-white/10 rounded-xl focus:border-lime-400 outline-none"
                            placeholder="Enter your email">
                    </div>

                </div>

                <!-- Password -->
                <div>
                    <label class="text-sm text-gray-300">Password</label>
                    <input type="password" name="password"
                        class="w-full mt-2 p-3 bg-black/60 border border-white/10 rounded-xl focus:border-lime-400 outline-none"
                        placeholder="Create password">
                </div>

                <!-- Confirm -->
                <div>
                    <label class="text-sm text-gray-300">Confirm Password</label>
                    <input type="password" name="confirmPassword"
                        class="w-full mt-2 p-3 bg-black/60 border border-white/10 rounded-xl focus:border-lime-400 outline-none"
                        placeholder="Confirm password">
                </div>

                <!-- Terms -->
                <div class="flex items-center gap-2 text-sm text-gray-400">
                    <input type="checkbox" class="accent-lime-400">
                    <span>I agree to Terms & Privacy Policy</span>
                </div>

                <!-- BUTTON -->
                <button type="submit"
                    class="w-full bg-lime-400 hover:bg-lime-300 text-black font-bold py-3 rounded-xl transition">
                    Create Account
                </button>

            </form>


        </div>
    </div>

</div>

<script>
const form = document.querySelector('form');
const errorContainer = document.getElementById('error-container');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  errorContainer.classList.add('hidden');
  errorContainer.innerHTML = '';

  const formData = new FormData(form);
  const data = Object.fromEntries(formData.entries());

  try {
    const response = await fetch('/register', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });

    const result = await response.json();

    if (response.ok && result.success) {
      // Redirect to OTP verification page
      window.location.href = `/verify-otp?email=${encodeURIComponent(result.email)}`;
    } else {
      errorContainer.classList.remove('hidden');
      if (result.errors && Array.isArray(result.errors)) {
        errorContainer.innerHTML = result.errors.join('<br>');
      } else {
        errorContainer.textContent = result.message || 'Registration failed. Please check inputs.';
      }
    }
  } catch (error) {
    errorContainer.classList.remove('hidden');
    errorContainer.textContent = 'A network error occurred. Please try again.';
  }
});
</script>
