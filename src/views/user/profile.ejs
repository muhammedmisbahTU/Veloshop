<div class="max-w-6xl mx-auto px-4 py-10">

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-10 bg-zinc-950 border border-white/5 p-6 rounded-3xl backdrop-blur-xl">
        <div class="flex flex-col sm:flex-row items-center gap-5">
            <!-- Avatar -->
            <div class="relative">
                <% if (profileUser.avatar) { %>
                    <img src="<%= profileUser.avatar %>" alt="Profile Picture" class="w-24 h-24 rounded-full object-cover border-2 border-lime-400">
                <% } else { %>
                    <div class="w-24 h-24 rounded-full bg-zinc-900 border-2 border-dashed border-zinc-700 flex items-center justify-center text-3xl font-bold text-lime-400">
                        <%= profileUser.fullName.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
            </div>

            <!-- Profile Text -->
            <div class="text-center sm:text-left">
                <h1 class="text-3xl font-extrabold text-white"><%= profileUser.fullName %></h1>
                <p class="text-gray-400 text-sm mt-1"><%= profileUser.email %></p>
                <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mt-3">
                    <span class="px-3 py-1 bg-lime-400/10 border border-lime-400/30 text-lime-400 text-xs font-semibold rounded-full">
                        <%= profileUser.role %>
                    </span>
                    <% if (profileUser.isEmailVerified) { %>
                        <span class="px-3 py-1 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-semibold rounded-full flex items-center gap-1">
                            Verified
                        </span>
                    <% } else { %>
                        <span class="px-3 py-1 bg-amber-500/10 border border-amber-500/30 text-amber-400 text-xs font-semibold rounded-full flex items-center gap-1">
                            Unverified
                        </span>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-3 w-full md:w-auto">
            <!-- Referral Details -->
            <div class="bg-black/40 border border-white/5 rounded-2xl p-4 text-center">
                <p class="text-xs text-gray-500 uppercase font-semibold">Referral Code</p>
                <p class="text-lg font-mono font-bold text-lime-400 mt-1"><%= profileUser.referralId || 'N/A' %></p>
            </div>
            
            <a href="/profile/edit" class="w-full md:w-auto text-center px-6 py-3 bg-lime-400 hover:bg-lime-300 text-black font-bold rounded-xl transition duration-300">
                Edit Profile Settings
            </a>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

       

        <!-- Address Management Section -->
        <div class="lg:col-span-2 space-y-6">
            
            <div class="bg-zinc-950 border border-white/5 rounded-3xl p-6 sm:p-8">
                
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-white">My Shipping Addresses</h2>
                    <button id="showAddFormBtn" class="text-lime-400 text-sm font-semibold hover:underline">
                        + Add Address
                    </button>
                </div>

                <div id="address-alert-container" class="hidden rounded-xl p-4 text-sm mb-5 text-center"></div>

                <!-- Add Address Form (Hidden by default) -->
                <form id="addAddressForm" class="hidden space-y-4 bg-black/40 border border-white/5 p-5 rounded-2xl mb-8">
                    <h3 class="font-bold text-white mb-2">New Address Details</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="text-xs text-gray-400">Address Line 1</label>
                            <input type="text" name="addressLine1" placeholder="Street address, P.O. Box" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="text-xs text-gray-400">Address Line 2 (Optional)</label>
                            <input type="text" name="addressLine2" placeholder="Apartment, suite, unit, building" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
                        <div class="sm:col-span-2">
                            <label class="text-xs text-gray-400">City</label>
                            <input type="text" name="city" placeholder="City" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="text-xs text-gray-400">State / Region</label>
                            <input type="text" name="state" placeholder="State" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="text-xs text-gray-400">PIN / Zip Code</label>
                            <input type="number" name="pinCode" placeholder="Code" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="text-xs text-gray-400">Country</label>
                            <input type="text" name="country" placeholder="Country" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                        </div>
                        <div class="flex items-center gap-2 pt-6">
                            <input type="checkbox" name="IsDefault" value="true" id="isDefaultCheck" class="accent-lime-400 w-4 h-4">
                            <label for="isDefaultCheck" class="text-sm text-gray-300 cursor-pointer">Set as default address</label>
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 pt-4 border-t border-white/5">
                        <button type="button" id="cancelAddBtn" class="px-4 py-2 border border-white/10 hover:border-white/30 text-gray-300 text-sm rounded-lg">
                            Cancel
                        </button>
                        <button type="submit" class="px-4 py-2 bg-lime-400 hover:bg-lime-300 text-black font-semibold text-sm rounded-lg transition">
                            Save Address
                        </button>
                    </div>
                </form>

                <!-- Addresses List -->
                <div class="space-y-4" id="addressList">
                    <% if (addresses && addresses.length > 0) { %>
                        <% addresses.forEach(address => { %>
                            <div class="bg-black/20 border border-white/5 hover:border-lime-400/20 p-5 rounded-2xl flex justify-between items-start transition" id="addr-card-<%= address._id %>">
                                <div class="space-y-1 text-sm">
                                    <div class="flex items-center gap-2">
                                        <span class="font-bold text-white"><%= address.city %>, <%= address.country %></span>
                                        <% if (address.IsDefault) { %>
                                            <span class="px-2 py-0.5 bg-lime-400/10 text-lime-400 text-2xs font-semibold rounded-full border border-lime-400/30">
                                                Default
                                            </span>
                                        <% } %>
                                    </div>
                                    <p class="text-gray-400"><%= address.addressLine1 %></p>
                                    <% if (address.addressLine2) { %>
                                        <p class="text-gray-400"><%= address.addressLine2 %></p>
                                    <% } %>
                                    <p class="text-gray-500 text-xs">PIN: <%= address.pinCode %> | State: <%= address.state %></p>
                                </div>
                                <div class="flex gap-2">
                                    <button
                                        class="edit-address-btn text-xs text-lime-400 border border-lime-400/10 hover:bg-lime-400/10 px-3 py-1.5 rounded-lg transition"
                                        data-id="<%= address._id %>"
                                        data-address-line1="<%= address.addressLine1 %>"
                                        data-address-line2="<%= address.addressLine2 || '' %>"
                                        data-city="<%= address.city %>"
                                        data-state="<%= address.state %>"
                                        data-pincode="<%= address.pinCode %>"
                                        data-country="<%= address.country %>"
                                        data-default="<%= address.IsDefault ? 'true' : 'false' %>"
                                    >
                                        Edit
                                    </button>
                                    <button class="delete-address-btn text-xs text-red-400 border border-red-400/10 hover:bg-red-400/10 px-3 py-1.5 rounded-lg transition" data-id="<%= address._id %>">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-10 bg-black/10 border border-dashed border-zinc-800 rounded-2xl">
                            <p class="text-gray-500 text-sm">No shipping addresses saved yet.</p>
                        </div>
                    <% } %>
                </div>

            </div>

        </div>

    </div>

</div>

<div id="editAddressModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 px-4">
    <div class="w-full max-w-2xl border border-white/10 bg-zinc-950 p-6 shadow-2xl">
        <div class="mb-5 flex items-center justify-between gap-4">
            <h3 class="text-xl font-bold text-white">Edit Address</h3>
            <button id="closeEditModalBtn" type="button" class="text-sm font-semibold text-gray-400 hover:text-white">Close</button>
        </div>

        <form id="editAddressForm" class="space-y-4">
            <input type="hidden" name="id" id="editAddressId">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="text-xs text-gray-400">Address Line 1</label>
                    <input type="text" name="addressLine1" id="editAddressLine1" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                </div>
                <div>
                    <label class="text-xs text-gray-400">Address Line 2</label>
                    <input type="text" name="addressLine2" id="editAddressLine2" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none">
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
                <div class="sm:col-span-2">
                    <label class="text-xs text-gray-400">City</label>
                    <input type="text" name="city" id="editCity" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                </div>
                <div>
                    <label class="text-xs text-gray-400">State</label>
                    <input type="text" name="state" id="editState" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                </div>
                <div>
                    <label class="text-xs text-gray-400">PIN Code</label>
                    <input type="number" name="pinCode" id="editPinCode" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="text-xs text-gray-400">Country</label>
                    <input type="text" name="country" id="editCountry" class="w-full mt-1 bg-zinc-900 border border-white/10 rounded-xl p-3 text-sm focus:border-lime-400 focus:outline-none" required>
                </div>
                <div class="flex items-center gap-2 pt-6">
                    <input type="checkbox" name="IsDefault" value="true" id="editIsDefault" class="accent-lime-400 w-4 h-4">
                    <label for="editIsDefault" class="text-sm text-gray-300 cursor-pointer">Set as default address</label>
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-white/5">
                <button type="button" id="cancelEditAddressBtn" class="px-4 py-2 border border-white/10 hover:border-white/30 text-gray-300 text-sm rounded-lg">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-lime-400 hover:bg-lime-300 text-black font-semibold text-sm rounded-lg transition">Update Address</button>
            </div>
        </form>
    </div>
</div>

<script>
const showAddFormBtn = document.getElementById("showAddFormBtn");
const cancelAddBtn = document.getElementById("cancelAddBtn");
const addAddressForm = document.getElementById("addAddressForm");
const addressAlert = document.getElementById("address-alert-container");
const editAddressModal = document.getElementById("editAddressModal");
const editAddressForm = document.getElementById("editAddressForm");
const closeEditModalBtn = document.getElementById("closeEditModalBtn");
const cancelEditAddressBtn = document.getElementById("cancelEditAddressBtn");

function openEditModal(button) {
    document.getElementById("editAddressId").value = button.dataset.id;
    document.getElementById("editAddressLine1").value = button.dataset.addressLine1 || "";
    document.getElementById("editAddressLine2").value = button.dataset.addressLine2 || "";
    document.getElementById("editCity").value = button.dataset.city || "";
    document.getElementById("editState").value = button.dataset.state || "";
    document.getElementById("editPinCode").value = button.dataset.pincode || "";
    document.getElementById("editCountry").value = button.dataset.country || "";
    document.getElementById("editIsDefault").checked = button.dataset.default === "true";
    editAddressModal.classList.remove("hidden");
    editAddressModal.classList.add("flex");
}

function closeEditModal() {
    editAddressModal.classList.add("hidden");
    editAddressModal.classList.remove("flex");
    editAddressForm.reset();
}

showAddFormBtn.addEventListener("click", () => {
    addAddressForm.classList.remove("hidden");
    showAddFormBtn.classList.add("hidden");
});

cancelAddBtn.addEventListener("click", () => {
    addAddressForm.classList.add("hidden");
    showAddFormBtn.classList.remove("hidden");
    addAddressForm.reset();
});

addAddressForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    addressAlert.classList.add("hidden");
    addressAlert.className = "rounded-xl p-4 text-sm mb-5 text-center";

    const formData = new FormData(addAddressForm);
    const data = Object.fromEntries(formData.entries());
    // checkbox handling
    data.IsDefault = formData.get("IsDefault") === "true";

    try {
        const response = await fetch("/addresses", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok && result.success) {
            addressAlert.classList.remove("hidden");
            addressAlert.classList.add("bg-lime-500/10", "border", "border-lime-500/30", "text-lime-400");
            addressAlert.textContent = result.message || "Address added successfully!";
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            addressAlert.classList.remove("hidden");
            addressAlert.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
            addressAlert.textContent = result.message || "Failed to add address.";
        }
    } catch (err) {
        addressAlert.classList.remove("hidden");
        addressAlert.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
        addressAlert.textContent = "A network error occurred. Please try again.";
    }
});

document.querySelectorAll(".edit-address-btn").forEach(btn => {
    btn.addEventListener("click", () => openEditModal(btn));
});

closeEditModalBtn.addEventListener("click", closeEditModal);
cancelEditAddressBtn.addEventListener("click", closeEditModal);

editAddressModal.addEventListener("click", (e) => {
    if (e.target === editAddressModal) {
        closeEditModal();
    }
});

editAddressForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    addressAlert.classList.add("hidden");
    addressAlert.className = "rounded-xl p-4 text-sm mb-5 text-center";

    const id = document.getElementById("editAddressId").value;
    const formData = new FormData(editAddressForm);
    const data = Object.fromEntries(formData.entries());
    data.IsDefault = formData.get("IsDefault") === "true";
    delete data.id;

    try {
        const response = await fetch(`/addresses/edit/${id}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok && result.success) {
            addressAlert.classList.remove("hidden");
            addressAlert.classList.add("bg-lime-500/10", "border", "border-lime-500/30", "text-lime-400");
            addressAlert.textContent = result.message || "Address updated successfully.";
            closeEditModal();
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            addressAlert.classList.remove("hidden");
            addressAlert.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
            addressAlert.textContent = result.message || "Failed to update address.";
        }
    } catch (err) {
        addressAlert.classList.remove("hidden");
        addressAlert.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
        addressAlert.textContent = "A network error occurred. Please try again.";
    }
});

// Delete address
const deleteBtns = document.querySelectorAll(".delete-address-btn");
deleteBtns.forEach(btn => {
    btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id");
        if (!confirm("Are you sure you want to delete this address?")) return;

        addressAlert.classList.add("hidden");
        addressAlert.className = "rounded-xl p-4 text-sm mb-5 text-center";

        try {
            const response = await fetch(`/addresses/delete/${id}`, {
                method: "POST"
            });

            const result = await response.json();

            if (response.ok && result.success) {
                addressAlert.classList.remove("hidden");
                addressAlert.classList.add("bg-lime-500/10", "border", "border-lime-500/30", "text-lime-400");
                addressAlert.textContent = result.message || "Address deleted!";
                document.getElementById(`addr-card-${id}`).remove();
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
            } else {
                addressAlert.classList.remove("hidden");
                addressAlert.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
                addressAlert.textContent = result.message || "Failed to delete address.";
            }
        } catch (err) {
            addressAlert.classList.remove("hidden");
            addressAlert.classList.add("bg-red-500/10", "border", "border-red-500/30", "text-red-400");
            addressAlert.textContent = "A network error occurred. Please try again.";
        }
    });
});
</script>
