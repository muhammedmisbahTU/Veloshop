<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title || "Veloshop Admin" %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-black text-white">
    <div class="flex min-h-screen">
        <aside class="hidden w-64 border-r border-white/10 bg-zinc-950 px-5 py-6 lg:block">
            <a href="/admin/users" class="block text-2xl font-black text-lime-400">VELOSHOP</a>
            <p class="mt-1 text-xs uppercase tracking-[0.24em] text-zinc-500">Admin</p>

            <nav class="mt-10 space-y-2 text-sm font-semibold text-zinc-300">
                <a href="/admin/users" class="block border border-lime-400/30 bg-lime-400/10 px-4 py-3 text-lime-400">Users</a>
                <a href="/" class="block border border-white/10 px-4 py-3 hover:border-lime-400/50 hover:text-lime-400">Storefront</a>
                <a href="/logout" class="block border border-white/10 px-4 py-3 hover:border-red-400/50 hover:text-red-400">Logout</a>
            </nav>
        </aside>

        <div class="min-w-0 flex-1">
            <header class="flex items-center justify-between border-b border-white/10 bg-zinc-950/80 px-5 py-4">
                <div>
                    <p class="text-xs uppercase tracking-[0.22em] text-lime-400">Control Panel</p>
                    <h1 class="text-xl font-black text-white"><%= title || "Admin" %></h1>
                </div>
                <div class="text-right text-sm">
                    <p class="font-semibold text-white"><%= locals.user ? locals.user.fullName : "Admin" %></p>
                    <p class="text-xs text-zinc-500"><%= locals.user ? locals.user.email : "" %></p>
                </div>
            </header>

            <main class="px-5 py-6">
                <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                    <div class="mb-5 border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-300"><%= errorMessage %></div>
                <% } %>
                <% if (typeof successMessage !== 'undefined' && successMessage) { %>
                    <div class="mb-5 border border-lime-500/30 bg-lime-500/10 p-4 text-sm text-lime-300"><%= successMessage %></div>
                <% } %>
                <%- body %>
            </main>
        </div>
    </div>
</body>
</html>
