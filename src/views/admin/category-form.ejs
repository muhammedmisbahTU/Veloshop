<section class="mx-auto max-w-3xl space-y-6">
    <div>
        <a href="/admin/categories" class="text-sm font-bold text-lime-400 hover:text-lime-300">Back to Categories</a>
        <h2 class="mt-3 text-3xl font-black text-white"><%= mode === "edit" ? "Edit Category" : "Add Category" %></h2>
        <p class="mt-2 text-sm text-zinc-400">Category slugs are generated automatically from the name.</p>
    </div>

    <% if (formErrors && formErrors.length) { %>
        <div class="border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-300">
            <% formErrors.forEach(error => { %>
                <p><%= error %></p>
            <% }) %>
        </div>
    <% } %>

    <form method="POST" action="<%= mode === 'edit' ? `/admin/categories/${category._id}` : '/admin/categories' %>" class="space-y-5 border border-white/10 bg-zinc-950 p-6">
        <div>
            <label class="mb-2 block text-sm font-semibold text-zinc-300">Category Name</label>
            <input
                type="text"
                name="name"
                value="<%= category ? category.name : '' %>"
                placeholder="Example: Gaming Keyboards"
                class="w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400"
                required
            >
        </div>

        <label class="flex items-center gap-3 border border-white/10 bg-black px-4 py-3">
            <input
                type="checkbox"
                name="isActive"
                value="on"
                class="h-4 w-4 accent-lime-400"
                <%= !category || category.isActive ? "checked" : "" %>
            >
            <span class="text-sm font-semibold text-zinc-300">Active category</span>
        </label>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a href="/admin/categories" class="border border-white/10 px-5 py-3 text-center text-sm font-bold text-zinc-300 hover:border-lime-400 hover:text-lime-400">Cancel</a>
            <button type="submit" class="bg-lime-400 px-5 py-3 text-sm font-black text-black hover:bg-lime-300">
                <%= mode === "edit" ? "Update Category" : "Create Category" %>
            </button>
        </div>
    </form>
</section>
