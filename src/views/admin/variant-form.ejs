<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

<section class="mx-auto max-w-4xl space-y-6">
    <div>
        <a href="/admin/products/<%= product._id %>/variants" class="text-sm font-bold text-lime-400 hover:text-lime-300">Back to Variants</a>
        <h2 class="mt-3 text-3xl font-black text-white"><%= mode === "edit" ? "Edit Variant" : "Add Variant" %></h2>
        <p class="mt-2 text-sm text-zinc-400"><%= product.name %> requires at least <%= minImages %> images per variant.</p>
    </div>

    <% if (formErrors && formErrors.length) { %>
        <div class="border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-300">
            <% formErrors.forEach(error => { %>
                <p><%= error %></p>
            <% }) %>
        </div>
    <% } %>

    <form id="variantForm" method="POST" enctype="multipart/form-data" action="<%= mode === 'edit' ? `/admin/variants/${variant._id}` : `/admin/products/${product._id}/variants` %>" class="space-y-5 border border-white/10 bg-zinc-950 p-6">
        <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
            <div>
                <div class="mb-2 flex items-center justify-between gap-3">
                    <label class="block text-sm font-semibold text-zinc-300">SKU</label>
                    <button type="button" id="generateSkuBtn" class="text-xs font-bold text-lime-400 hover:text-lime-300">Generate from attributes</button>
                </div>
                <input id="skuInput" type="text" name="sku" value="<%= variant ? variant.sku : '' %>" data-base="<%= skuBase %>" class="w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400">
                <p class="mt-2 text-xs text-zinc-500">Auto-generated from product and variant attributes, but you can edit it manually.</p>
            </div>

            <div>
                <label class="mb-2 block text-sm font-semibold text-zinc-300">Stock</label>
                <input type="number" name="stock" min="0" value="<%= variant ? variant.stock : 0 %>" class="w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400" required>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
            <div>
                <label class="mb-2 block text-sm font-semibold text-zinc-300">Regular Price</label>
                <input type="number" name="regularPrice" min="0" step="0.01" value="<%= variant ? variant.regularPrice : '' %>" class="w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400" required>
            </div>

            <div>
                <label class="mb-2 block text-sm font-semibold text-zinc-300">Sale Price</label>
                <input type="number" name="salePrice" min="0" step="0.01" value="<%= variant && variant.salePrice != null ? variant.salePrice : '' %>" class="w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400">
            </div>
        </div>

        <div class="space-y-3">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <label class="block text-sm font-semibold text-zinc-300">Attributes</label>
                    <p class="mt-1 text-xs text-zinc-500">Add proper variant attributes like Color, Size, Storage, or Material.</p>
                </div>
                <button type="button" id="addAttributeBtn" class="border border-lime-400/30 px-4 py-2 text-xs font-bold text-lime-400 hover:bg-lime-400/10">Add Attribute</button>
            </div>

            <div id="attributeRows" class="space-y-3">
                <% attributeRows.forEach(attribute => { %>
                    <div class="attribute-row grid grid-cols-1 gap-3 sm:grid-cols-[1fr_1fr_auto]">
                        <input type="text" name="attributeName" value="<%= attribute.name %>" placeholder="Name, e.g. Color" class="attribute-name w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400">
                        <input type="text" name="attributeValue" value="<%= attribute.value %>" placeholder="Value, e.g. Black" class="attribute-value w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400">
                        <button type="button" class="remove-attribute border border-red-400/30 px-4 py-3 text-xs font-bold text-red-400 hover:bg-red-400/10">Remove</button>
                    </div>
                <% }) %>
            </div>
        </div>

        <% if (mode === "edit" && variant && variant.images && variant.images.length) { %>
            <div class="space-y-3">
                <p class="text-sm font-semibold text-zinc-300">Current Images (<%= variant.images.length %>)</p>
                <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
                    <% variant.images.forEach(image => { %>
                        <img src="<%= image %>" alt="<%= variant.sku %>" class="aspect-square w-full border border-white/10 object-cover">
                    <% }) %>
                </div>
                <label class="flex items-center gap-3 border border-white/10 bg-black px-4 py-3">
                    <input type="checkbox" name="replaceImages" value="on" class="h-4 w-4 accent-lime-400">
                    <span class="text-sm font-semibold text-zinc-300">Replace all current images with the new uploads</span>
                </label>
            </div>
        <% } %>

        <div>
            <label class="mb-2 block text-sm font-semibold text-zinc-300">Variant Images</label>
            <input id="variantImagesInput" type="file" name="images" accept="image/jpeg,image/png,image/webp" multiple class="w-full border border-white/10 bg-black px-4 py-3 text-sm text-zinc-300 file:mr-4 file:border-0 file:bg-lime-400 file:px-4 file:py-2 file:text-sm file:font-bold file:text-black" <%= mode === "create" ? "required" : "" %>>
            <p class="mt-2 text-xs text-zinc-500">Upload at least <%= minImages %> images. Images are automatically auto-cropped to a square initially, but you can click "Crop Image" on any preview card to adjust it manually.</p>
            <p id="imageProcessingStatus" class="mt-2 hidden text-xs font-bold text-lime-400"></p>
            <div id="imagePreviewGrid" class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4"></div>
        </div>

        <label class="flex items-center gap-3 border border-white/10 bg-black px-4 py-3">
            <input type="checkbox" name="isActive" value="on" class="h-4 w-4 accent-lime-400" <%= !variant || variant.isActive ? "checked" : "" %>>
            <span class="text-sm font-semibold text-zinc-300">Active variant</span>
        </label>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a href="/admin/products/<%= product._id %>/variants" class="border border-white/10 px-5 py-3 text-center text-sm font-bold text-zinc-300 hover:border-lime-400 hover:text-lime-400">Cancel</a>
            <button type="submit" class="bg-lime-400 px-5 py-3 text-sm font-black text-black hover:bg-lime-300">
                <%= mode === "edit" ? "Update Variant" : "Create Variant" %>
            </button>
        </div>
    </form>

    <!-- Cropping Modal -->
    <div id="cropperModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/80 p-4">
        <div class="w-full max-w-2xl border border-white/10 bg-zinc-950 p-6 flex flex-col max-h-[90vh]">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-white">Manual Crop (1:1 Aspect Ratio)</h3>
                <button type="button" id="closeCropperModal" class="text-zinc-400 hover:text-white text-2xl font-bold">&times;</button>
            </div>
            <div class="flex-1 min-h-[300px] max-h-[50vh] bg-black overflow-hidden flex items-center justify-center">
                <img id="cropperImage" class="max-w-full max-h-full block">
            </div>
            <div class="flex justify-end gap-3 mt-4">
                <button type="button" id="cancelCropBtn" class="border border-white/10 px-4 py-2 text-sm font-semibold text-zinc-300 hover:border-lime-400 hover:text-lime-400">Cancel</button>
                <button type="button" id="saveCropBtn" class="bg-lime-400 px-4 py-2 text-sm font-black text-black hover:bg-lime-300">Save Crop</button>
            </div>
        </div>
    </div>
</section>

<script>
const skuInput = document.getElementById("skuInput");
const addAttributeBtn = document.getElementById("addAttributeBtn");
const attributeRows = document.getElementById("attributeRows");
const generateSkuBtn = document.getElementById("generateSkuBtn");
const variantForm = document.getElementById("variantForm");
const variantImagesInput = document.getElementById("variantImagesInput");
const imagePreviewGrid = document.getElementById("imagePreviewGrid");
const imageProcessingStatus = document.getElementById("imageProcessingStatus");
const submitButton = variantForm.querySelector("button[type='submit']");

// Modal Elements
const cropperModal = document.getElementById("cropperModal");
const cropperImage = document.getElementById("cropperImage");
const closeCropperModal = document.getElementById("closeCropperModal");
const cancelCropBtn = document.getElementById("cancelCropBtn");
const saveCropBtn = document.getElementById("saveCropBtn");

let originalFiles = [];
let processedFiles = [];
let imageProcessingPromise = Promise.resolve();
let cropperInstance = null;
let currentCropIndex = null;

function skuPart(value) {
    return String(value || "")
        .trim()
        .toUpperCase()
        .replace(/[^A-Z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
}

function buildSku() {
    const base = skuPart(skuInput.dataset.base || "PRODUCT");
    const values = Array.from(document.querySelectorAll(".attribute-value"))
        .map(input => skuPart(input.value))
        .filter(Boolean)
        .join("-");

    return values ? `${base}-${values}`.slice(0, 80) : base.slice(0, 80);
}

function refreshSkuIfEmpty() {
    if (!skuInput.value.trim()) {
        skuInput.value = buildSku();
    }
}

function bindAttributeRow(row) {
    row.querySelectorAll("input").forEach(input => {
        input.addEventListener("input", refreshSkuIfEmpty);
    });

    row.querySelector(".remove-attribute").addEventListener("click", () => {
        const rows = document.querySelectorAll(".attribute-row");
        if (rows.length === 1) {
            row.querySelectorAll("input").forEach(input => {
                input.value = "";
            });
        } else {
            row.remove();
        }
        refreshSkuIfEmpty();
    });
}

document.querySelectorAll(".attribute-row").forEach(bindAttributeRow);

addAttributeBtn.addEventListener("click", () => {
    const row = document.createElement("div");
    row.className = "attribute-row grid grid-cols-1 gap-3 sm:grid-cols-[1fr_1fr_auto]";
    row.innerHTML = `
        <input type="text" name="attributeName" placeholder="Name, e.g. Color" class="attribute-name w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400">
        <input type="text" name="attributeValue" placeholder="Value, e.g. Black" class="attribute-value w-full border border-white/10 bg-black px-4 py-3 text-sm text-white outline-none focus:border-lime-400">
        <button type="button" class="remove-attribute border border-red-400/30 px-4 py-3 text-xs font-bold text-red-400 hover:bg-red-400/10">Remove</button>
    `;
    attributeRows.appendChild(row);
    bindAttributeRow(row);
});

generateSkuBtn.addEventListener("click", () => {
    skuInput.value = buildSku();
});

refreshSkuIfEmpty();

function readImage(file) {
    return new Promise((resolve, reject) => {
        const image = new Image();
        const url = URL.createObjectURL(file);

        image.onload = () => {
            URL.revokeObjectURL(url);
            resolve(image);
        };

        image.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error(`Unable to read ${file.name}`));
        };

        image.src = url;
    });
}

function canvasToBlob(canvas) {
    return new Promise((resolve, reject) => {
        canvas.toBlob((blob) => {
            if (blob) {
                resolve(blob);
                return;
            }
            reject(new Error("Image processing failed."));
        }, "image/webp", 0.86);
    });
}

async function cropResizeImage(file, index) {
    const image = await readImage(file);
    const sourceSize = Math.min(image.naturalWidth, image.naturalHeight);
    const sourceX = Math.floor((image.naturalWidth - sourceSize) / 2);
    const sourceY = Math.floor((image.naturalHeight - sourceSize) / 2);
    const canvas = document.createElement("canvas");
    canvas.width = 1000;
    canvas.height = 1000;

    const context = canvas.getContext("2d");
    context.drawImage(image, sourceX, sourceY, sourceSize, sourceSize, 0, 0, 1000, 1000);

    const blob = await canvasToBlob(canvas);
    const safeName = file.name.replace(/\.[^.]+$/, "").replace(/[^a-z0-9-]+/gi, "-").replace(/^-+|-+$/g, "") || `variant-${index + 1}`;

    return new File([blob], `${safeName}-1000.webp`, {
        type: "image/webp",
        lastModified: Date.now()
    });
}

function setProcessedFiles(files) {
    const dataTransfer = new DataTransfer();
    files.forEach(file => dataTransfer.items.add(file));
    variantImagesInput.files = dataTransfer.files;
}

function renderImagePreviews(files) {
    imagePreviewGrid.innerHTML = "";

    files.forEach((file, index) => {
        const url = URL.createObjectURL(file);
        const wrapper = document.createElement("div");
        wrapper.className = "relative group border border-white/10 bg-zinc-950 p-2 space-y-2";
        wrapper.innerHTML = `
            <div class="relative aspect-square w-full overflow-hidden bg-black">
                <img src="${url}" alt="${file.name}" class="aspect-square w-full object-cover">
                <div class="absolute inset-0 flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button type="button" class="crop-trigger-btn bg-lime-400 text-black text-xs font-black px-3 py-2 hover:bg-lime-300">
                        Crop Image
                    </button>
                </div>
            </div>
            <p class="truncate text-xs text-zinc-400 text-center">${file.name}</p>
        `;
        imagePreviewGrid.appendChild(wrapper);

        wrapper.querySelector(".crop-trigger-btn").addEventListener("click", () => {
            openCropModal(index);
        });

        wrapper.querySelector("img").addEventListener("load", () => {
            URL.revokeObjectURL(url);
        }, { once: true });
    });
}

function openCropModal(index) {
    currentCropIndex = index;
    const file = originalFiles[index];
    if (!file) return;

    const fileUrl = URL.createObjectURL(file);
    cropperImage.src = fileUrl;
    cropperModal.classList.remove("hidden");

    cropperInstance = new Cropper(cropperImage, {
        aspectRatio: 1,
        viewMode: 1,
        dragMode: 'move',
        responsive: true,
        restore: false,
        guides: true,
        center: true,
        highlight: false,
        cropBoxMovable: true,
        cropBoxResizable: true,
        toggleDragModeOnDblclick: false
    });
}

function closeCropModal() {
    cropperModal.classList.add("hidden");
    if (cropperInstance) {
        cropperInstance.destroy();
        cropperInstance = null;
    }
    if (cropperImage.src) {
        URL.revokeObjectURL(cropperImage.src);
        cropperImage.src = "";
    }
    currentCropIndex = null;
}

closeCropperModal.addEventListener("click", closeCropModal);
cancelCropBtn.addEventListener("click", closeCropModal);

saveCropBtn.addEventListener("click", async () => {
    if (currentCropIndex === null || !cropperInstance) return;

    saveCropBtn.disabled = true;
    saveCropBtn.textContent = "Saving...";

    try {
        const canvas = cropperInstance.getCroppedCanvas({
            width: 1000,
            height: 1000
        });

        const blob = await canvasToBlob(canvas);
        const originalFile = originalFiles[currentCropIndex];
        const safeName = originalFile.name.replace(/\.[^.]+$/, "").replace(/[^a-z0-9-]+/gi, "-").replace(/^-+|-+$/g, "") || `variant-${currentCropIndex + 1}`;

        const newFile = new File([blob], `${safeName}-1000.webp`, {
            type: "image/webp",
            lastModified: Date.now()
        });

        processedFiles[currentCropIndex] = newFile;
        setProcessedFiles(processedFiles);
        renderImagePreviews(processedFiles);
        closeCropModal();
    } catch (err) {
        alert(err.message || "Failed to crop image.");
    } finally {
        saveCropBtn.disabled = false;
        saveCropBtn.textContent = "Save Crop";
    }
});

async function processSelectedImages() {
    const files = Array.from(variantImagesInput.files || []);
    imagePreviewGrid.innerHTML = "";
    originalFiles = [...files];

    if (!files.length) {
        processedFiles = [];
        imageProcessingStatus.classList.add("hidden");
        return;
    }

    if (files.length > 10) {
        alert("Maximum 10 images are allowed.");
        variantImagesInput.value = "";
        originalFiles = [];
        processedFiles = [];
        return;
    }

    submitButton.disabled = true;
    submitButton.classList.add("opacity-60", "cursor-not-allowed");
    imageProcessingStatus.classList.remove("hidden");
    imageProcessingStatus.textContent = "Preparing preview images...";

    try {
        processedFiles = await Promise.all(files.map((file, idx) => cropResizeImage(file, idx)));
        setProcessedFiles(processedFiles);
        renderImagePreviews(processedFiles);
        imageProcessingStatus.textContent = `${processedFiles.length} image${processedFiles.length === 1 ? "" : "s"} ready for upload. Click "Crop Image" on any preview to adjust crop manually.`;
    } catch (error) {
        imageProcessingStatus.classList.remove("hidden");
        imageProcessingStatus.textContent = error.message || "Could not process selected images.";
        variantImagesInput.value = "";
        originalFiles = [];
        processedFiles = [];
        imagePreviewGrid.innerHTML = "";
    } finally {
        submitButton.disabled = false;
        submitButton.classList.remove("opacity-60", "cursor-not-allowed");
    }
}

variantImagesInput.addEventListener("change", () => {
    imageProcessingPromise = processSelectedImages();
});

variantForm.addEventListener("submit", async (event) => {
    if (imageProcessingPromise) {
        event.preventDefault();
        submitButton.disabled = true;
        await imageProcessingPromise;
        submitButton.disabled = false;
        variantForm.submit();
    }
});
</script>
