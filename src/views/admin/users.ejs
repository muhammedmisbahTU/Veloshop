<section class="space-y-5">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-lime-400">Users</p>
            <h2 class="mt-2 text-3xl font-black text-white">User Management</h2>
            <p class="mt-2 text-sm text-zinc-400"><%= totalUsers %> matching account<%= totalUsers === 1 ? "" : "s" %></p>
        </div>

        <form id="filterForm" method="GET" action="/admin/users" class="flex w-full flex-col gap-2 sm:flex-row sm:flex-wrap lg:w-auto">
            <input
                type="search"
                name="search"
                value="<%= search %>"
                placeholder="Search name or email"
                class="w-full border border-white/10 bg-zinc-950 px-4 py-3 text-sm text-white outline-none focus:border-lime-400 sm:w-64"
            >
            <button type="submit" class="bg-lime-400 px-5 py-3 text-sm font-black text-black hover:bg-lime-300">Search</button>
            <% const hasFilters = search || filterStatus !== 'all' || filterRole !== 'all' || filterProvider !== 'all' || sort !== 'desc' || sortBy !== 'createdAt'; %>
            <% if (hasFilters) { %>
                <a href="/admin/users" class="border border-white/10 px-5 py-3 text-center text-sm font-bold text-zinc-300 hover:border-lime-400 hover:text-lime-400">Reset</a>
            <% } %>
        </form>
    </div>

    <!-- Filter Bar -->
    <div class="flex flex-wrap items-center gap-3 border border-white/10 bg-zinc-950/60 px-5 py-3.5">
        <span class="text-xs font-bold uppercase tracking-widest text-zinc-500 mr-1">Filters</span>

        <!-- Status -->
        <select id="filterStatus" class="border border-white/10 bg-black px-3 py-2 text-xs text-white outline-none focus:border-lime-400 rounded-none appearance-none cursor-pointer">
            <option value="all" <%= filterStatus === 'all' ? 'selected' : '' %>>All Status</option>
            <option value="active" <%= filterStatus === 'active' ? 'selected' : '' %>>Active</option>
            <option value="blocked" <%= filterStatus === 'blocked' ? 'selected' : '' %>>Blocked</option>
        </select>

        <!-- Role -->
        <select id="filterRole" class="border border-white/10 bg-black px-3 py-2 text-xs text-white outline-none focus:border-lime-400 rounded-none appearance-none cursor-pointer">
            <option value="all" <%= filterRole === 'all' ? 'selected' : '' %>>All Roles</option>
            <option value="user" <%= filterRole === 'user' ? 'selected' : '' %>>User</option>
            <option value="admin" <%= filterRole === 'admin' ? 'selected' : '' %>>Admin</option>
        </select>

        <!-- Provider -->
        <select id="filterProvider" class="border border-white/10 bg-black px-3 py-2 text-xs text-white outline-none focus:border-lime-400 rounded-none appearance-none cursor-pointer">
            <option value="all" <%= filterProvider === 'all' ? 'selected' : '' %>>All Providers</option>
            <option value="local" <%= filterProvider === 'local' ? 'selected' : '' %>>Local</option>
            <option value="google" <%= filterProvider === 'google' ? 'selected' : '' %>>Google</option>
        </select>

        <!-- Sort By -->
        <select id="filterSortBy" class="border border-white/10 bg-black px-3 py-2 text-xs text-white outline-none focus:border-lime-400 rounded-none appearance-none cursor-pointer">
            <option value="createdAt" <%= sortBy === 'createdAt' ? 'selected' : '' %>>Sort: Joined</option>
            <option value="fullName" <%= sortBy === 'fullName' ? 'selected' : '' %>>Sort: Name</option>
            <option value="email" <%= sortBy === 'email' ? 'selected' : '' %>>Sort: Email</option>
            <!-- <option value="role" <%= sortBy === 'role' ? 'selected' : '' %>>Sort: Role</option>
            <option value="authProvider" <%= sortBy === 'authProvider' ? 'selected' : '' %>>Sort: Provider</option>
            <option value="isActive" <%= sortBy === 'isActive' ? 'selected' : '' %>>Sort: Status</option> -->
        </select>

        <!-- Sort Order -->
        <select id="filterSortOrder" class="border border-white/10 bg-black px-3 py-2 text-xs text-white outline-none focus:border-lime-400 rounded-none appearance-none cursor-pointer">
            <option value="desc" <%= sort === 'desc' ? 'selected' : '' %>>Descending</option>
            <option value="asc" <%= sort === 'asc' ? 'selected' : '' %>>Ascending</option>
        </select>

    </div>

    <div id="adminUserAlert" class="hidden border p-4 text-sm"></div>

    <div class="overflow-x-auto border border-white/10 bg-zinc-950">
        <table class="min-w-full divide-y divide-white/10 text-left text-sm">
            <thead class="bg-black text-xs uppercase tracking-widest text-zinc-500">
                <tr>
                    <%
                        // Helper to build a sort-toggle URL for a column header
                        function sortUrl(field) {
                            const newOrder = (sortBy === field && sort === 'asc') ? 'desc' : 'asc';
                            let qs = `?sortBy=${field}&sort=${newOrder}`;
                            if (search) qs += `&search=${encodeURIComponent(search)}`;
                            if (filterStatus !== 'all') qs += `&status=${filterStatus}`;
                            if (filterRole !== 'all') qs += `&role=${filterRole}`;
                            if (filterProvider !== 'all') qs += `&provider=${filterProvider}`;
                            return `/admin/users${qs}`;
                        }
                        function sortIcon(field) {
                            if (sortBy !== field) return '';
                            return sort === 'asc' ? ' ASC' : ' DESC';
                        }
                    %>
                    <th class="px-5 py-4">
                        <a href="<%= sortUrl('fullName') %>" class="hover:text-lime-400 inline-flex items-center gap-1 <%= sortBy === 'fullName' ? 'text-lime-400' : '' %>">
                            User<%= sortIcon('fullName') %>
                        </a>
                    </th>
                    <th class="px-5 py-4">
                        <a href="<%= sortUrl('role') %>" class="hover:text-lime-400 inline-flex items-center gap-1 <%= sortBy === 'role' ? 'text-lime-400' : '' %>">
                            Role<%= sortIcon('role') %>
                        </a>
                    </th>
                    <th class="px-5 py-4">
                        <a href="<%= sortUrl('authProvider') %>" class="hover:text-lime-400 inline-flex items-center gap-1 <%= sortBy === 'authProvider' ? 'text-lime-400' : '' %>">
                            Provider<%= sortIcon('authProvider') %>
                        </a>
                    </th>
                    <th class="px-5 py-4">
                        <a href="<%= sortUrl('isActive') %>" class="hover:text-lime-400 inline-flex items-center gap-1 <%= sortBy === 'isActive' ? 'text-lime-400' : '' %>">
                            Status<%= sortIcon('isActive') %>
                        </a>
                    </th>
                    <th class="px-5 py-4">
                        <a href="<%= sortUrl('createdAt') %>" class="hover:text-lime-400 inline-flex items-center gap-1 <%= sortBy === 'createdAt' ? 'text-lime-400' : '' %>">
                            Joined<%= sortIcon('createdAt') %>
                        </a>
                    </th>
                    <th class="px-5 py-4 text-right">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
                <% if (users && users.length) { %>
                    <% users.forEach(user => { %>
                        <tr id="user-row-<%= user._id %>">
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-3">
                                    <% if (user.avatar) { %>
                                        <img src="<%= user.avatar %>" alt="<%= user.fullName %>" class="h-10 w-10 rounded-full object-cover">
                                    <% } else { %>
                                        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-black text-sm font-black text-lime-400"><%= user.fullName.charAt(0).toUpperCase() %></div>
                                    <% } %>
                                    <div>
                                        <p class="font-bold text-white"><%= user.fullName %></p>
                                        <p class="text-xs text-zinc-500"><%= user.email %></p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-4 text-zinc-300"><%= user.role %></td>
                            <td class="px-5 py-4 text-zinc-300"><%= user.authProvider %></td>
                            <td class="px-5 py-4">
                                <% if (user.isActive) { %>
                                    <span class="inline-flex border border-lime-400/30 bg-lime-400/10 px-3 py-1 text-xs font-bold text-lime-400">ACTIVE</span>
                                <% } else { %>
                                    <span class="inline-flex border border-red-400/30 bg-red-400/10 px-3 py-1 text-xs font-bold text-red-400">BLOCKED</span>
                                <% } %>
                            </td>
                            <td class="px-5 py-4 text-zinc-400"><%= new Date(user.createdAt).toLocaleDateString() %></td>
                            <td class="px-5 py-4 text-right">
                                <% const isCurrentAdmin = locals.user && (locals.user.id || locals.user._id).toString() === user._id.toString(); %>
                                <% if (isCurrentAdmin) { %>
                                    <span class="text-xs text-zinc-500">Current admin</span>
                                <% } else if (user.isActive) { %>
                                    <button class="status-action border border-red-400/30 px-4 py-2 text-xs font-bold text-red-400 hover:bg-red-400/10" data-id="<%= user._id %>" data-action="block" data-name="<%= user.fullName %>">Block</button>
                                <% } else { %>
                                    <button class="status-action border border-lime-400/30 px-4 py-2 text-xs font-bold text-lime-400 hover:bg-lime-400/10" data-id="<%= user._id %>" data-action="unblock" data-name="<%= user.fullName %>">Unblock</button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="px-5 py-12 text-center text-zinc-500">No users found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-zinc-500">Page <%= page %> of <%= totalPages %></p>
        <div class="flex gap-2">
            <%
                let querySuffix = '';
                if (search) querySuffix += `&search=${encodeURIComponent(search)}`;
                if (sort !== 'desc') querySuffix += `&sort=${encodeURIComponent(sort)}`;
                if (sortBy !== 'createdAt') querySuffix += `&sortBy=${encodeURIComponent(sortBy)}`;
                if (filterStatus !== 'all') querySuffix += `&status=${encodeURIComponent(filterStatus)}`;
                if (filterRole !== 'all') querySuffix += `&role=${encodeURIComponent(filterRole)}`;
                if (filterProvider !== 'all') querySuffix += `&provider=${encodeURIComponent(filterProvider)}`;
            %>
            <% if (page > 1) { %>
                <a href="/admin/users?page=<%= page - 1 %><%= querySuffix %>" class="border border-white/10 px-4 py-2 text-sm font-bold text-zinc-300 hover:border-lime-400 hover:text-lime-400">Previous</a>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/admin/users?page=<%= page + 1 %><%= querySuffix %>" class="border border-white/10 px-4 py-2 text-sm font-bold text-zinc-300 hover:border-lime-400 hover:text-lime-400">Next</a>
            <% } %>
        </div>
    </div>
</section>

<script>
const adminUserAlert = document.getElementById("adminUserAlert");

// Filter dropdown auto-apply
function applyFilters() {
    const params = new URLSearchParams(window.location.search);

    // Read current values from the dropdowns
    const status = document.getElementById("filterStatus").value;
    const role = document.getElementById("filterRole").value;
    const provider = document.getElementById("filterProvider").value;
    const sortByVal = document.getElementById("filterSortBy").value;
    const sortOrderVal = document.getElementById("filterSortOrder").value;

    // Preserve the search term
    const search = params.get("search") || "";

    const qs = new URLSearchParams();
    if (search) qs.set("search", search);
    if (status !== "all") qs.set("status", status);
    if (role !== "all") qs.set("role", role);
    if (provider !== "all") qs.set("provider", provider);
    if (sortByVal !== "createdAt") qs.set("sortBy", sortByVal);
    if (sortOrderVal !== "desc") qs.set("sort", sortOrderVal);

    const qsStr = qs.toString();
    window.location.href = "/admin/users" + (qsStr ? "?" + qsStr : "");
}

document.getElementById("filterStatus").addEventListener("change", applyFilters);
document.getElementById("filterRole").addEventListener("change", applyFilters);
document.getElementById("filterProvider").addEventListener("change", applyFilters);
document.getElementById("filterSortBy").addEventListener("change", applyFilters);
document.getElementById("filterSortOrder").addEventListener("change", applyFilters);

// Block / Unblock
document.querySelectorAll(".status-action").forEach(button => {
    button.addEventListener("click", async () => {
        const action = button.dataset.action;
        const userId = button.dataset.id;
        const userName = button.dataset.name;
        const label = action === "block" ? "block" : "unblock";

        const confirmResult = await Swal.fire({
            title: `${label} ${userName}`,
            text: `Are you sure you want to ${label} ${userName}?`,
            icon: 'warning',
            iconColor: '#f87171',
            showCancelButton: true,
            confirmButtonText: `Yes, ${label} it`,
            cancelButtonText: 'Cancel',
            background: '#09090b',
            color: '#ffffff',
            customClass: {
                popup: 'rounded-3xl border border-white/5 bg-zinc-950 p-6',
                title: 'text-xl font-bold text-white',
                htmlContainer: 'text-gray-400 text-sm mt-2',
                confirmButton: 'px-5 py-2.5 bg-red-500 hover:bg-red-600 text-white font-semibold text-sm rounded-xl transition mx-2 focus:outline-none',
                cancelButton: 'px-5 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-gray-300 font-semibold text-sm rounded-xl transition mx-2 focus:outline-none'
            },
            buttonsStyling: false
        });

        if (!confirmResult.isConfirmed) {
            return;
        }

        try {
            const response = await fetch(`/admin/users/${userId}/${action}`, {
                method: "POST"
            });
            const result = await response.json();

            adminUserAlert.className = "border p-4 text-sm";
            adminUserAlert.classList.remove("hidden");

            if (response.ok && result.success) {
                adminUserAlert.classList.add("border-lime-500/30", "bg-lime-500/10", "text-lime-300");
                adminUserAlert.textContent = result.message || "User updated.";
                setTimeout(() => window.location.reload(), 900);
                return;
            }

            adminUserAlert.classList.add("border-red-500/30", "bg-red-500/10", "text-red-300");
            adminUserAlert.textContent = result.message || "Action failed.";
        } catch (error) {
            adminUserAlert.className = "border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-300";
            adminUserAlert.classList.remove("hidden");
            adminUserAlert.textContent = "A network error occurred. Please try again.";
        }
    });
});
</script>
