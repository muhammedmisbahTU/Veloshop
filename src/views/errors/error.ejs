

  <section class=" px-6 py-12 mx-auto text-center  border-gray-100 rounded-2xl shadow-xl">
    
    <!-- Large Status Code Display -->
    <h1 class="text-8xl font-black tracking-tight text-indigo-600 sm:text-9xl mb-4">
      <%= status %>
    </h1>
    
    <!-- Clean, User-Friendly Error Header -->
    <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-3">
      <%= title %>
    </h2>
    
    <!-- Descriptive message passed from your controller -->
    <p class="text-base text-gray-500 max-w-md mx-auto mb-8">
      <%= message %>
    </p>

    <!-- Navigation Action Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a href="/" class="w-full sm:w-auto px-6 py-3 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg shadow-sm transition-colors duration-200">
        Back to Storefront
      </a>
      <button onclick="window.history.back()" class="w-full sm:w-auto px-6 py-3 text-sm font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors duration-200">
        Go Back Previous Page
      </button>
    </div>

    <!-- DEVELOPER ZONE: Only prints out when your project is in Development Mode -->
    <% if (error && error.stack) { %>
      <div class="mt-8 border-t border-red-200 pt-6 text-left">
        <h3 class="text-sm font-semibold text-red-600 uppercase tracking-wider mb-2">
          🛠️ Developer Diagnostics (Hidden in Production)
        </h3>
        <pre class="p-4 bg-gray-900 text-red-400 text-xs font-mono rounded-lg overflow-x-auto leading-relaxed shadow-inner max-h-60">
<%= error.stack %>
        </pre>
      </div>
    <% } %>

  </section>

